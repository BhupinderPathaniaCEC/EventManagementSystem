@model EventManagement.Application.DTOs.EventDto

@{
    ViewData["Title"] = "Edit Event";
}

<h1 class="mb-4">Edit Event</h1>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Organizer" class="form-label"></label>
            <input asp-for="Organizer" class="form-control" />
            <span asp-validation-for="Organizer" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="StartDate" class="form-label"></label>
            <input asp-for="StartDate" type="date" class="form-control" />
            <span asp-validation-for="StartDate" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="EndDate" class="form-label"></label>
            <input asp-for="EndDate" type="date" class="form-control" />
            <span asp-validation-for="EndDate" class="text-danger"></span>
        </div>
    </div>

    <h4 class="mt-4 mb-2">Tickets</h4>
    <button type="button" id="addTicketBtn" class="btn btn-success btn-sm mb-2">+ Add Ticket</button>

    <table class="table table-bordered" id="ticketsTable">
        <thead class="table-light">
            <tr>
                <th style="width:5%">#</th>
                <th>Ticket No</th>
                <th>Price</th>
                <th style="width:15%">Actions</th>
            </tr>
        </thead>
        <tbody id="ticketsBody">
        </tbody>
    </table>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary">Update Event</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        let rowIdx = 0;

        function addRow(ticketNo = '', price = '') {
            rowIdx++;
            const row = `
                <tr data-idx="${rowIdx}">
                    <td>${rowIdx}</td>
                    <td><input type="text" name="Tickets[${rowIdx - 1}].TicketNo" value="${ticketNo}" class="form-control ticket-no" required /></td>
                    <td><input type="number" name="Tickets[${rowIdx - 1}].Price" value="${price}" class="form-control ticket-price" step="0.01" min="0" required /></td>
                    <td>
                        <button type="button" class="btn btn-sm btn-outline-primary edit-btn">Edit</button>
                        <button type="button" class="btn btn-sm btn-outline-danger delete-btn">Delete</button>
                    </td>
                </tr>`;
            $('#ticketsBody').append(row);
            reindex();
        }

        function reindex() {
            $('#ticketsBody tr').each(function (i) {
                $(this).find('.ticket-no').attr('name', `Tickets[${i}].TicketNo`);
                $(this).find('.ticket-price').attr('name', `Tickets[${i}].Price`);
                $(this).find('td:first').text(i + 1);
            });
        }

        // Load existing tickets on page load
        @foreach (var t in Model.Tickets)
        {
            <text>addRow('@t.TicketNo', '@t.Price');</text>
        }

        $('#addTicketBtn').click(function () {
            addRow();
        });

        $('#ticketsBody').on('click', '.delete-btn', function () {
            $(this).closest('tr').remove();
            reindex();
        });

        $('#ticketsBody').on('click', '.edit-btn', function () {
            const row = $(this).closest('tr');
            const noInput = row.find('.ticket-no');
            const priceInput = row.find('.ticket-price');

            if ($(this).text().trim() === 'Edit') {
                noInput.prop('readonly', false).focus();
                priceInput.prop('readonly', false);
                $(this).text('Done').removeClass('btn-outline-primary').addClass('btn-primary');
            } else {
                noInput.prop('readonly', true);
                priceInput.prop('readonly', true);
                $(this).text('Edit').removeClass('btn-primary').addClass('btn-outline-primary');
            }
        });
    </script>
}
