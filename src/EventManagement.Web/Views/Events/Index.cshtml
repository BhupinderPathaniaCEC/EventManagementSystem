@model List<EventManagement.Application.DTOs.EventDto>

@{
    ViewData["Title"] = "Events";
}

<h1 class="mb-4">Events</h1>

<a asp-action="Create" class="btn btn-primary mb-3">
    <i class="bi bi-plus-circle"></i> Create New Event
</a>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Organizer</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Tickets</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var e in Model)
        {
            <tr>
                <td>@e.Name</td>
                <td>@e.Organizer</td>
                <td>@e.StartDate.ToString("yyyy-MM-dd")</td>
                <td>@e.EndDate.ToString("yyyy-MM-dd")</td>
                <td>
                    <span class="badge bg-info">@e.Tickets.Count</span>
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                    <form asp-action="Delete" asp-route-id="@e.Id" method="post" class="d-inline"
                          onsubmit="return confirm('Delete this event?');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
